---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PortfolioCard from '../../components/PortfolioCard.astro';

const items = (await getCollection('portfolio')).sort(
  (a, b) => (a.data.position ?? 99) - (b.data.position ?? 99)
);

const allTags = ['All', ...Array.from(new Set(items.flatMap(i => i.data.tags))).sort()];
---

<BaseLayout title="Portfolio" description="Selected technical writing work by Dave Lewis.">
  <div class="max-w-5xl mx-auto px-6 py-24 sm:py-28">
    <h1 class="text-6xl sm:text-7xl font-serif font-normal tracking-[-0.025em] text-slate-900 dark:text-white">Portfolio</h1>
    <p class="mt-3 text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
      Selected technical writing work including end-user and administrator documentation and migrations.
      Filter by discipline or scan the full list.
    </p>

    <!-- Filter bar -->
    <div class="mt-10 pt-5 pb-5 border-t border-b border-slate-200 dark:border-slate-800 flex items-center justify-between gap-4 flex-wrap">
      <div class="flex flex-wrap gap-2" id="filter-chips">
        {allTags.map((tag, i) => (
          <button
            data-filter={tag === 'All' ? 'all' : tag.toLowerCase()}
            class:list={[
              "px-3.5 py-1.5 rounded-full text-sm font-medium transition-colors border",
              i === 0
                ? "bg-blue-700 text-white border-transparent dark:bg-blue-700"
                : "bg-transparent text-slate-600 dark:text-slate-400 border-slate-200 dark:border-slate-700 hover:border-slate-400 dark:hover:border-slate-500",
            ]}
          >
            {tag}
          </button>
        ))}
      </div>
      <p class="font-mono text-xs text-slate-400 dark:text-slate-500 shrink-0" id="result-count">
        {items.length} results · sorted by recency
      </p>
    </div>

    <!-- Grid -->
    <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-7" id="portfolio-grid">
      {items.map((item) => (
        <PortfolioCard
          title={item.data.title}
          summary={item.data.summary}
          tags={item.data.tags}
          date={item.data.date}
          id={item.id}
          featured={item.data.featured}
          thumbnail={item.data.thumbnail}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('#filter-chips button');
  const cards = document.querySelectorAll<HTMLAnchorElement>('#portfolio-grid a');
  const counter = document.getElementById('result-count')!;

  const activeClasses = ['bg-blue-700', 'text-white', 'border-transparent', 'dark:bg-blue-700'];
  const inactiveClasses = ['bg-transparent', 'text-slate-600', 'dark:text-slate-400', 'border-slate-200', 'dark:border-slate-700'];

  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      const filter = chip.dataset.filter!;

      chips.forEach(c => {
        c.classList.remove(...activeClasses);
        c.classList.add(...inactiveClasses);
      });
      chip.classList.remove(...inactiveClasses);
      chip.classList.add(...activeClasses);

      let visible = 0;
      cards.forEach(card => {
        const tags: string[] = JSON.parse(card.dataset.tags ?? '[]');
        const show = filter === 'all' || tags.includes(filter);
        card.hidden = !show;
        if (show) visible++;
      });

      counter.textContent = `${visible} result${visible === 1 ? '' : 's'} · sorted by recency`;
    });
  });
</script>
