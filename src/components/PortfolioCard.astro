---
interface Props {
  title: string;
  summary: string;
  tags: string[];
  date: Date;
  id: string;
}

const { title, summary, tags, date, id } = Astro.props;
const year = date.getFullYear();
---

<a
  href={`/portfolio/${id}`}
  class="group flex flex-col rounded-lg border border-slate-200 dark:border-slate-800 p-6 hover:border-blue-300 dark:hover:border-blue-700 hover:shadow-sm transition-all"
>
  <div class="flex items-start justify-between gap-4 mb-3">
    <h2 class="text-lg font-semibold text-slate-900 dark:text-white group-hover:text-blue-700 dark:group-hover:text-blue-400 transition-colors leading-snug">
      {title}
    </h2>
    <span class="shrink-0 text-xs text-slate-400 dark:text-slate-500 mt-0.5">{year}</span>
  </div>
  <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed flex-1">
    {summary}
  </p>
  <ul class="flex flex-wrap gap-2 mt-4">
    {tags.map((tag) => (
      <li class="px-2.5 py-1 rounded-full bg-slate-100 dark:bg-slate-800 font-mono text-xs text-slate-600 dark:text-slate-400">
        {tag}
      </li>
    ))}
  </ul>
</a>
