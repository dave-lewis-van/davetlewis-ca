---
interface Props {
  title: string;
  summary: string;
  tags: string[];
  date: Date;
  id: string;
  featured?: boolean;
  thumbnail?: string;
}

const { title, summary, tags, date, id, featured = false, thumbnail } = Astro.props;
const year = date.getFullYear();
const tagsJson = JSON.stringify(tags.map(t => t.toLowerCase()));
const visibleTags = tags.slice(0, featured ? 4 : 3);
---

<a
  href={`/portfolio/${id}`}
  data-tags={tagsJson}
  class:list={[
    "group flex flex-col rounded-lg border border-slate-200 dark:border-slate-800 hover:border-blue-300 dark:hover:border-blue-700 hover:shadow-sm transition-all overflow-hidden",
    featured && "sm:col-span-2 sm:flex-row",
  ]}
>
  <!-- Thumbnail -->
  <div class:list={[
    "shrink-0 bg-slate-100 dark:bg-slate-800",
    featured ? "sm:w-1/2 aspect-video sm:aspect-auto" : "aspect-[3/1]",
  ]}>
    {thumbnail ? (
      <img
        src={thumbnail}
        alt={title}
        class="w-full h-full object-cover"
      />
    ) : (
      <div class="w-full h-full" style="background: repeating-linear-gradient(135deg, #f8fafc, #f8fafc 8px, #eef2f7 8px, #eef2f7 16px);" />
    )}
  </div>

  <!-- Content -->
  <div class:list={[
    "flex flex-col flex-1",
    featured ? "p-8" : "p-6",
  ]}>
    {featured && (
      <span class="inline-block mb-3 px-2.5 py-1 rounded-full bg-blue-50 dark:bg-blue-950/40 text-xs font-medium text-blue-700 dark:text-blue-400 uppercase tracking-widest self-start">
        Featured
      </span>
    )}
    <div class="flex items-start justify-between gap-4 mb-3">
      <h2 class:list={[
        "font-semibold text-slate-900 dark:text-white group-hover:text-blue-700 dark:group-hover:text-blue-400 transition-colors leading-snug",
        featured ? "text-2xl" : "text-lg",
      ]}>
        {title}
      </h2>
      <span class="shrink-0 text-xs text-slate-400 dark:text-slate-500 mt-0.5">{year}</span>
    </div>
    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed flex-1">
      {summary}
    </p>
    <ul class="flex flex-wrap gap-2 mt-4">
      {visibleTags.map((tag) => (
        <li class="px-2.5 py-1 rounded-full bg-blue-50 dark:bg-blue-950/40 text-xs text-blue-700 dark:text-blue-400">
          {tag}
        </li>
      ))}
    </ul>
  </div>
</a>
