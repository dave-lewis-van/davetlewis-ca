---
const year = new Date().getFullYear();

const links = [
  {
    href: 'mailto:davetlewis.van@gmail.com',
    label: 'Email',
    title: 'davetlewis.van@gmail.com',
  },
  {
    href: 'https://linkedin.com/in/davetlewis',
    label: 'LinkedIn',
    title: 'linkedin.com/in/davetlewis',
  },
  {
    href: 'https://github.com/dave-lewis-van',
    label: 'GitHub',
    title: 'github.com/dave-lewis-van',
  },
];
---

<footer class="border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 mt-auto">
  <div class="max-w-5xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-sm text-slate-500 dark:text-slate-400">
      &copy; {year} DTL Communications
    </p>
    <ul class="flex items-center gap-6">
      {links.map(({ href, label, title }) => (
        <li>
          <a
            href={href}
            title={title}
            class="text-sm text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white transition-colors"
            {...href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</footer>
